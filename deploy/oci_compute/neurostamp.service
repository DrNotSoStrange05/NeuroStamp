[Unit]
Description=NeuroStamp Gunicorn Uvicorn service
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/NeuroStamp
Environment="PATH=/home/ubuntu/NeuroStamp/venv/bin"
ExecStart=/home/ubuntu/NeuroStamp/venv/bin/gunicorn main:app -k uvicorn.workers.UvicornWorker -b 127.0.0.1:8000 --workers 3 --log-level info
Restart=on-failure

[Install]
WantedBy=multi-user.target
