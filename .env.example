# Copy this file to .env and fill in your values
# (Never commit .env to git — it's already in .gitignore)

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (get this from Neon, Supabase, or your own server)
# Leave unset to use local SQLite for development
DATABASE_URL=postgresql://user:password@host:5432/neurostamp

# ── Encryption ────────────────────────────────────────────────────────────────
# Fernet key for encrypting watermark keys at rest.
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=

# ── App Security ──────────────────────────────────────────────────────────────
# Random hex string for signing session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
NEUROSTAMP_APP_SECRET=

# ── Optional ──────────────────────────────────────────────────────────────────
# Comma-separated usernames allowed to access /db-viewer (leave empty = any logged-in user)
NEUROSTAMP_ADMIN_USERS=

# Set to "true" when running behind HTTPS in production
NEUROSTAMP_SECURE_COOKIES=false

# Max upload size in MB (default: 20)
NEUROSTAMP_MAX_UPLOAD_MB=20
